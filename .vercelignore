# Exclude local desktop build artifacts and sidecar binaries from deployments
# These files are large and not needed by the Vercel-hosted frontend/API

# Tauri build outputs
src-tauri/target/
src-tauri/bundle/

# Sidecar and bundled node binaries
src-tauri/sidecar/
src-tauri/**/node

# macOS disk images and app bundles
**/*.dmg
**/*.app

# Rust/Cargo build artifacts (safety)
target/

# Common local artifacts
.DS_Store

# Startup Intelligence deploy surface:
# exclude retained non-core API domains that are still being refactored for
# Startup Intelligence.
api/cyber/
api/infrastructure/
api/supply-chain/
api/bootstrap.js
api/eia/

# Exclude legacy server-side World Monitor handlers from Startup Intelligence
# deployments while these retained domains are refactored into startup namespace.
server/worldmonitor/cyber/
server/worldmonitor/infrastructure/
server/worldmonitor/intelligence/
server/worldmonitor/supply-chain/
