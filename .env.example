ALLOW_UNAUTHENTICATED_RELAY=false
RELAY_METRICS_WINDOW_SECONDS=60
NOTIFICATION_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Startup Intelligence <alerts@startupintelligence.app>


# ------ Site Configuration ------

VITE_VARIANT=tech
VITE_WS_API_URL=
VITE_SENTRY_DSN=
