# ============================================
# Startup Intelligence — Environment Variables
# ============================================
# Copy this file to .env.local and fill only what you need.
# Empty keys disable the related optional capability.
#
#   cp .env.example .env.local
# ============================================


# ------ LLM / Analyst Workflows ------

GROQ_API_KEY=
OPENROUTER_API_KEY=
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
OLLAMA_API_URL=
OLLAMA_MODEL=


# ------ Shared Cache / Freshness ------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ------ Startup / Market Intelligence ------

FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=


# ------ Research / AI Stack Sources ------

GITHUB_TOKEN=
HUGGINGFACE_TOKEN=
PRODUCT_HUNT_TOKEN=


# ------ Telegram Startup Intelligence ------

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL_SET=tech
VITE_TELEGRAM_BOT_USERNAME=StartupIntelBot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=


# ------ Relay / RSS / Notifications ------

WS_RELAY_URL=
VITE_WS_RELAY_URL=
RELAY_SHARED_SECRET=
