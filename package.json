{
  "name": "startup-intelligence",
  "private": true,
  "version": "2.6.7",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "lint": "biome lint ./src ./server ./api ./tests ./scripts ./middleware.ts",
    "lint:fix": "biome check ./src ./server ./api ./tests ./scripts ./middleware.ts --fix",
    "lint:boundaries": "node scripts/lint-boundaries.mjs",
    "lint:unicode": "node scripts/check-unicode-safety.mjs",
    "lint:unicode:staged": "node scripts/check-unicode-safety.mjs --staged",
    "lint:md": "markdownlint-cli2 '**/*.md' '!**/node_modules/**' '!.agent/**' '!.agents/**' '!.claude/**' '!.factory/**' '!.windsurf/**' '!skills/**' '!todos/**'",
    "version:sync": "node scripts/sync-desktop-version.mjs",
    "version:check": "node scripts/sync-desktop-version.mjs --check",
    "dev": "npm run dev:startup",
    "dev:startup": "cross-env VITE_VARIANT=startup vite",
    "build": "cross-env-shell VITE_VARIANT=startup \"tsc && vite build\"",
    "build:startup": "cross-env-shell VITE_VARIANT=startup \"tsc && vite build\"",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "typecheck:all": "tsc --noEmit && tsc --noEmit -p tsconfig.api.json",
    "preview": "vite preview",
    "test:data": "tsx --test tests/*.test.mjs tests/*.test.mts",
    "test:feeds": "node scripts/validate-rss-feeds.mjs",
    "test:sidecar": "node --test api/_cors.test.mjs api/cyber-threats.test.mjs api/usni-fleet.test.mjs scripts/ais-relay-rss.test.cjs api/loaders-xml-wms-regression.test.mjs",
    "test:convex": "vitest run --config vitest.config.mts",
    "test:convex:watch": "vitest --config vitest.config.mts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@bufbuild/buf": "^1.66.0",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.52.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/geojson": "^7946.0.14",
    "@types/maplibre-gl": "^1.13.2",
    "@types/marked": "^5.0.2",
    "@types/papaparse": "^5.5.2",
    "@types/supercluster": "^7.1.3",
    "@types/three": "^0.183.1",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "convex-test": "^0.0.43",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "exceljs": "^4.4.0",
    "h3-js": "^4.4.0",
    "markdownlint-cli2": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@clerk/clerk-js": "^5.56.0",
    "@deck.gl/aggregation-layers": "^9.2.11",
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@dodopayments/convex": "^0.2.8",
    "@protomaps/basemaps": "^5.7.1",
    "@sentry/browser": "^10.39.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^2.0.0",
    "@xenova/transformers": "^2.17.2",
    "canvas-confetti": "^1.9.4",
    "convex": "^1.32.0",
    "d3": "^7.9.0",
    "deck.gl": "^9.2.11",
    "dodopayments-checkout": "^1.8.0",
    "dompurify": "^3.1.7",
    "fast-xml-parser": "^5.3.7",
    "globe.gl": "^2.45.0",
    "hls.js": "^1.6.15",
    "i18next": "^25.8.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.2",
    "maplibre-gl": "^5.16.0",
    "marked": "^17.0.3",
    "onnxruntime-web": "^1.23.2",
    "papaparse": "^5.5.3",
    "pmtiles": "^4.4.0",
    "preact": "^10.25.4",
