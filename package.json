    "uqr": "^0.1.2",
    "ws": "^8.19.0",
    "youtubei.js": "^16.0.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.7",
    "serialize-javascript": "^7.0.4",
    "node-forge": "^1.4.0",
    "srvx": "^0.11.13"
  }
}
